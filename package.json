{
  "name": "claude-mux-demo",
  "version": "0.1.0",
  "main": "electron/main.js",
  "scripts": {
    "dev": "node -e \"try{require('child_process').execSync('taskkill /F /IM electron.exe',{stdio:'pipe'})}catch(e){}\" && concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build",
    "rebuild": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@babel/types": "^7.26.10",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.1.2",
    "electron": "^35.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "wait-on": "^8.0.3"
  }
}
